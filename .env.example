# ─────────────────────────────────────────────
#  JobRadar Backend — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (free tier)
# Get your URI from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/jobradar
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/jobradar

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: RapidAPI key for external job listings (https://rapidapi.com)
RAPID_API_KEY=your_rapidapi_key_here
